# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Shield Auth
SHIELD_INBOUND_SECRET=your-inbound-webhook-secret
SHIELD_ADMIN_SECRET=your-admin-dashboard-secret

# Microsoft 365
M365_TENANT_ID=your-tenant-id
M365_CLIENT_ID=your-app-client-id
M365_CLIENT_SECRET=your-app-client-secret

# Dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://your-dashboard-domain.com
